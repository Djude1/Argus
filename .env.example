DJANGO_SECRET_KEY=replace-with-a-local-dev-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true
ARGUS_AUTO_QUEUE_SCANS=true
PLAYWRIGHT_BROWSERS_PATH=.ms-playwright
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-a-local-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=60

# 注意：AI provider/model 由程式碼 hardcode（apps/agent/providers.py）
# AI_PROVIDER / AI_MODEL env 暫時不被讀取（過去殭屍配置，待後續整合）
ARGUS_AGENT_ENABLED=false
ARGUS_AGENT_MAX_STEPS=20
ARGUS_AGENT_MAX_TOKENS=60000
ARGUS_AGENT_STEP_TIMEOUT=30

# Google OAuth Client ID（一般使用者透過 Google 帳號登入時使用）
# 取得方式：Google Cloud Console > APIs & Services > Credentials > 建立 OAuth 用戶端 ID（Web application）
# 必須將 http://localhost:5173 與 http://localhost 加入「已授權的 JavaScript 來源」
# Backend 用於驗證 ID Token，Frontend 透過 Vite envPrefix 讀取同一個變數
GOOGLE_OAUTH_CLIENT_ID=

# 以下只填本機實際值；不可提交真正 API Key。
GLM_API_KEY=
MINIMAX_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=GoogleCloud_ApiKey.json

# Katana 補充型資安爬蟲（需安裝 Docker Desktop 並 pull 映像）
# docker pull projectdiscovery/katana:latest
KATANA_DOCKER_IMAGE=projectdiscovery/katana:latest
KATANA_TIMEOUT=90

# 首次 migrate 時自動建立的本機開發超級使用者（僅限本機；正式部署請留空並改用 createsuperuser）
ARGUS_BOOTSTRAP_SUPERUSER_USERNAME=
ARGUS_BOOTSTRAP_SUPERUSER_PASSWORD=

# ─────────────────────────────────────────────
# Email 寄送（購點收據、未來通知）
# ─────────────────────────────────────────────
# Dev 預設用 filebased（寄出的信存到 backend/dev_emails/*.log，可直接打開看）
# 想真實寄信時，把下面 DJANGO_EMAIL_BACKEND 改成 smtp.EmailBackend 並填 SMTP 設定
DJANGO_EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
# 切到真實 SMTP 時：
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Gmail SMTP 範例（強烈推薦，免費、穩定）
# 步驟：
#   1. 你的 Gmail 帳號 → 安全性 → 啟用「兩步驟驗證」（必要）
#   2. 安全性 → 應用程式密碼（App Password） → 選 Mail / Windows Computer → 產生 16 碼密碼
#   3. 把 16 碼貼到 EMAIL_HOST_PASSWORD（**不是**你的 Gmail 登入密碼）
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Argus 系統 <no-reply@argus.local>
