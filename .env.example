DJANGO_SECRET_KEY=replace-with-a-local-dev-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true
ARGUS_AUTO_QUEUE_SCANS=true
PLAYWRIGHT_BROWSERS_PATH=.ms-playwright
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-a-local-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=60

AI_PROVIDER=minimax
AI_MODEL=MiniMax-M2.7
AI_MAX_STEPS=20
AI_MAX_TOKENS=4096

# 以下只填本機實際值；不可提交真正 API Key。
GLM_API_KEY=
MINIMAX_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=GoogleCloud_ApiKey.json
